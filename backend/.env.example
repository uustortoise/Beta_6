# General Configuration
LOG_LEVEL=INFO
ENV=development

# Database Configuration
# Path is relative to the backend directory or absolute
DB_PATH=data/processed/residents_master_data.db

# Data Paths
DATA_ROOT=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
ARCHIVE_DATA_DIR=data/archive

# Security (Future Use)
# ENCRYPTION_ENABLED=False
# SECRET_KEY=change_me_in_production

# ML Configuration
MODEL_DIR=models
ANOMALY_THRESHOLD=3.0
CONFIDENCE_THRESHOLD=0.8

# Training-time unoccupied downsampling (optional tuning)
# Global knobs
# UNOCCUPIED_DOWNSAMPLE_MIN_SHARE=0.45
# UNOCCUPIED_DOWNSAMPLE_STRIDE=10
# UNOCCUPIED_BOUNDARY_KEEP=6
# UNOCCUPIED_MIN_RUN_LENGTH=24
#
# Per-room overrides (CSV map: room:value). Example:
# UNOCCUPIED_DOWNSAMPLE_STRIDE_BY_ROOM=bathroom:12,bedroom:4,entrance:14,kitchen:10,livingroom:12
# UNOCCUPIED_DOWNSAMPLE_MIN_SHARE_BY_ROOM=bathroom:0.08,entrance:0.08,livingroom:0.12,kitchen:0.14
# UNOCCUPIED_BOUNDARY_KEEP_BY_ROOM=bathroom:4
# UNOCCUPIED_MIN_RUN_LENGTH_BY_ROOM=bathroom:12

# Training-time minority-aware sampling (optional)
# ENABLE_MINORITY_CLASS_SAMPLING=true
# MINORITY_TARGET_SHARE=0.14
# MINORITY_MAX_MULTIPLIER=3
# MINORITY_TARGET_SHARE_BY_ROOM=bathroom:0.18,bedroom:0.25,entrance:0.22,kitchen:0.12,livingroom:0.15
# MINORITY_MAX_MULTIPLIER_BY_ROOM=bathroom:4,bedroom:6,entrance:5,kitchen:3,livingroom:3

# Walk-forward promotion gate room overrides (optional)
# WF_MIN_MINORITY_SUPPORT=0
# WF_MIN_MINORITY_SUPPORT_BY_ROOM=bathroom:6,entrance:6
# WF_STEP_DAYS_BY_ROOM=bathroom:1,entrance:1
# WF_DRIFT_THRESHOLD_BY_ROOM=bathroom:0.65,entrance:0.65
# WF_MAX_LOW_FOLDS_BY_ROOM=bathroom:1,entrance:1

# Pilot evidence profile for short-window timeline validation (optional)
# RELEASE_GATE_EVIDENCE_PROFILE=pilot_stage_a
# RELEASE_GATE_MIN_VALIDATION_CLASS_SUPPORT=10
# RELEASE_GATE_MIN_RECALL_SUPPORT=20
# RETRAIN_INPUT_MODE=incoming_only
# CLINICAL_PRIORITY_MULTIPLIERS=unoccupied:1.0,bedroom_normal_use:1.0,livingroom_normal_use:1.0,sleep:1.0
# CLINICAL_PRIORITY_MULTIPLIERS_BY_ROOM_LABEL=bedroom.unoccupied:1.0,bedroom.sleep:1.0,livingroom.unoccupied:1.0,livingroom.livingroom_normal_use:1.0,bathroom.unoccupied:1.0,bathroom.shower:1.0,bathroom.bathroom_normal_use:1.0

# Canonical resident identity aliases (optional)
# Format: alias=canonical,alias2=canonical2
# ELDER_ID_CANONICAL_MAP=HK0011_jessica=HK001_jessica

# PostgreSQL Configuration (Defaults for Local Dev)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=elderlycare
POSTGRES_DB=elderlycare

# Beta 5.5 Production Configuration Template
# Rename this file to .env in the backend directory on the production server

# General Configuration
LOG_LEVEL=INFO
ENV=production

# Database Configuration
# Use absolute paths for production safety
DB_PATH=/path/to/production/data/processed/residents_master_data.db

# Data Paths
# Use absolute paths to ensure the watcher monitors the correct directory
DATA_ROOT=/path/to/production/data
RAW_DATA_DIR=/path/to/production/data/raw
PROCESSED_DATA_DIR=/path/to/production/data/processed
ARCHIVE_DATA_DIR=/path/to/production/data/archive

# ML Configuration
MODEL_DIR=/path/to/production/backend/models
ANOMALY_THRESHOLD=3.0
CONFIDENCE_THRESHOLD=0.8
